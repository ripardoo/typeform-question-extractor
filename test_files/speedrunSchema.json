    {
      "id": "XuulZZYOqgpG",
      "title": "Which startup stages are you most interested in?",
      "ref": "51e0def4-5235-46ed-8112-9e5d4ca85f29",
      "properties": {
        "randomize": false,
        "allow_multiple_selection": true,
        "allow_other_choice": false,
        "vertical_alignment": true,
        "choices": [
          {
            "id": "i1TlYbwoBl8B",
            "ref": "8b3c1199-429c-4965-9ad4-c9cd115786bf",
            "label": "*Pre-Seed / Idea Stage. *Typically fewer than 10 employees. Product may change week to week. Very little structure, often <18 months of runway. High risk, high learning velocity."
          },
          {
            "id": "949wML4tFmp7",
            "ref": "a36f2324-53ec-4c19-99b6-a815ea72b1a5",
            "label": "*Seed Stage.* Team usually 10-25. First product in market or about to launch. Heavy iteration on customer feedback. Still scrappy, with modest funding (~12-24 months runway). Lots of hands-on responsibility."
          },
          {
            "id": "q0CkZIPV6kJJ",
            "ref": "f02c715a-bd46-4e86-b860-1df1ab7b4091",
            "label": "*Series A.* Team 25-75. Clearer product-market fit emerging. More defined roles but still startup pace. Company building repeatable go-to-market motion. Funding gives 18-24 months runway, growth expectations are high."
          },
          {
            "id": "MpgmaBwppmpd",
            "ref": "fa765885-2752-4a58-92aa-660b3372f5af",
            "label": "*Series B*. Team 75-200. Product and GTM motion scaling, company building leadership layers and specialized teams. Faster headcount growth, more defined processes, stronger financial footing but still significant risk."
          },
